/* pages/tvbox/tvbox.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.list {
  padding: 0 10rpx;
}

.item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}

.item-badge {
  font-size: 22rpx;
  color: #999;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.item-url {
  display: block;
  font-size: 26rpx;
  color: #666;
  word-break: break-all;
  margin-bottom: 10rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.item-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}
